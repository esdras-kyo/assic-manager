generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Evento {
  id              String       @id @default(cuid())
  slug            String       @unique
  nome            String
  descricao       String?
  inclui          String?
  local           String
  dataInicio      DateTime
  dataFim         DateTime?
  precoEmCentavos Int // sempre centavos, nunca float
  vagas           Int?
  status               EventoStatus        @default(RASCUNHO)
  modalidadePagamento  ModalidadePagamento @default(GATEWAY)
  pixManual            Json?
  conteudo             Json?
  camposPersonalizados Json?
  inscricoes           Inscricao[]
  criadoEm        DateTime     @default(now())
  atualizadoEm    DateTime     @updatedAt
}

enum EventoStatus {
  RASCUNHO
  ABERTO
  ENCERRADO
  CANCELADO
}

enum ModalidadePagamento {
  GATEWAY
  MANUAL
}

model Inscricao {
  id           String          @id @default(cuid())
  eventoId     String
  evento       Evento          @relation(fields: [eventoId], references: [id])
  nome         String
  email        String
  celular      String
  documento    String? // CPF — opcional; alguns eventos não coletam
  camposExtras Json? // campos extras coletados (flexível)
  status       InscricaoStatus @default(PENDENTE)
  pagamentos   Pagamento[]
  criadoEm     DateTime        @default(now())
  atualizadoEm DateTime        @updatedAt

  @@index([eventoId])
  @@index([status])
}

enum InscricaoStatus {
  PENDENTE // criada, sem pagamento confirmado
  CONFIRMADA // pagamento aprovado
  CANCELADA
  EXPIRADA // não pagou no prazo
}

model Pagamento {
  id               String          @id @default(cuid())
  inscricaoId      String
  inscricao        Inscricao       @relation(fields: [inscricaoId], references: [id])
  gateway          String // "pagarme", "mercadopago", "fake"
  gatewayPaymentId String          @unique // id no gateway
  metodo           MetodoPagamento
  status           PagamentoStatus @default(PENDING)
  amountInCents    Int
  // Dados do Pix devolvidos pelo gateway na criação — persistidos para
  // reexibir o código após refresh/retorno à página de pagamento.
  pixQrCode        String?
  pixExpiresAt     DateTime?
  criadoEm         DateTime        @default(now())
  atualizadoEm     DateTime        @updatedAt

  @@index([inscricaoId])
  @@index([gatewayPaymentId])
}

enum MetodoPagamento {
  PIX
  CREDIT_CARD
}

enum PagamentoStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  EXPIRED
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  senhaHash String
  nome      String
  criadoEm  DateTime @default(now())
}

// Token opaco p/ consulta de inscrições por email (magic link, validade 7d).
// Escopo = email: o link lista todas as inscrições daquele email.
model TokenConsulta {
  id       String   @id @default(cuid())
  token    String   @unique
  email    String
  expiraEm DateTime
  criadoEm DateTime @default(now())

  @@index([email])
}
