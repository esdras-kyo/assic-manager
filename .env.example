# Template de variáveis de ambiente. Copie para .env.local e preencha.
# Toda var nova entra aqui no mesmo commit do código que a usa.

# --- Banco (Postgres gerenciado; Supabase hoje, mas qualquer Postgres serve) ---
# Conexão pooled (runtime). Supabase: porta 6543 (pgbouncer).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Conexão direta (migrations). Supabase: porta 5432.
# Obs: a "direct connection" do Supabase é IPv6-only; em rede sem IPv6,
# use o session pooler (mesmo host do pooler, porta 5432).
# Senha com caractere especial precisa de URL-encoding (@ -> %40).
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# --- Pagamento ---
# Gateway ativo: fake | pagarme | mercadopago (fake = desenvolvimento)
PAYMENT_PROVIDER="fake"
# Assinatura do webhook do FakeGateway (só dev; opcional, tem default)
FAKE_WEBHOOK_SECRET="fake-dev-secret"
